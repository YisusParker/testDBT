  create or replace view `data-transformation-486715`.`exam2`.`int_customers_in_eu`
  OPTIONS()
  as WITH customers AS (
    SELECT
        id_cliente,
        nombre,
        contacto,
        direccion,
        ciudad,
        codigo_postal,
        pais

