),

eu_list AS (
    SELECT
        Country_name AS nombre
    FROM `data-transformation-486715`.`exam2`.`countriesEU`
)

SELECT
    c.id_cliente,
    c.nombre,
    c.contacto,
    c.direccion,
    c.ciudad,
    c.codigo_postal,
    c.pais,
    CASE WHEN e.nombre IS NOT NULL THEN 'EU' ELSE 'otro' END AS estado

FROM customers c
LEFT JOIN eu_list e
    ON c.pais = e.nombre;


