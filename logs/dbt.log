  create or replace view `data-transformation-486715`.`exam2_transformed`.`int_customers_in_eu`
  OPTIONS()
  as WITH customers AS (
    SELECT
        id_cliente,
        nombre,
        contacto,
        direccion,
        ciudad,
        codigo_postal,
        pais

    FROM `data-transformation-486715`.`exam2_transformed`.`stg_customers`
),

eu_list AS (
    SELECT
        Country_name AS nombre
    FROM `data-transformation-486715`.`exam2_transformed`.`countriesEU`
)

SELECT
    c.id_cliente,
    c.nombre,
    c.contacto,
    c.direccion,
    c.ciudad,
    c.codigo_postal,
    c.pais,
    CASE WHEN e.nombre IS NOT NULL THEN 'EU' ELSE 'otro' END AS estado

FROM customers c
LEFT JOIN eu_list e
    ON c.pais = e.nombre;


